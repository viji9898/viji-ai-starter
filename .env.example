# Public browser variable used by Google Identity Services on the React frontend.
VITE_GOOGLE_CLIENT_ID=

# Backend audience value used when verifying Google ID tokens in Netlify Functions.
GOOGLE_CLIENT_ID=
# Allowed Google Workspace domain for signed-in human users.
ALLOWED_EMAIL_DOMAIN=example.com
# Comma-separated admin email list used to assign the admin role after backend verification.
ADMIN_EMAILS=admin@example.com
# Optional comma-separated allowlist for non-admin sign-in users; these users do not receive admin access.
ALLOWED_SIGNIN_EMAILS=

# Optional Postgres connection string for backend-only database access.
DATABASE_URL=

# Google Cloud project id tied to the service account.
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=
# Service account client email used for delegated machine authentication.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
# Service account private key; preserve escaped newlines when storing it here.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Workspace user the service account impersonates for Google Workspace API access.
GOOGLE_IMPERSONATION_USER=assistant@example.com
# Optional Admin SDK customer id override; defaults to my_customer when omitted.
GOOGLE_DIRECTORY_CUSTOMER_ID=
# Comma-separated operational mailboxes allowed for delegated domain task queries.
GOOGLE_MAILBOXES=accounts@viji.com,design@xo.lk,projects@xo.lk,vendors@xo.lk,x@viji.com,pr@viji.com

# Optional ids used by the Docs and Sheets test endpoints.
GOOGLE_DOCS_TEST_DOCUMENT_ID=
GOOGLE_SHEETS_TEST_SPREADSHEET_ID=

# Legacy aliases still supported by the backend helper.
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Optional OpenAI API key for future backend-only AI features.
OPENAI_API_KEY=
# Optional SendGrid API key for backend-only email provider tests and email features.
SENDGRID_API_KEY=